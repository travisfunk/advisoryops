[32m+[m[32m        <dt class="cell-1_1">For Immediate Release:</dt>[m
[32m+[m[32m                  <dd class="cell-2_1"><time datetime="2020-03-03T05:00:00Z">March 03, 2020</time>[m
[32m+[m[32m</dd>[m
[32m+[m[41m                 [m
[32m+[m[41m                [m
[32m+[m[32m      </dl>[m
[32m+[m[32m    </div>[m
