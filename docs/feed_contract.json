{
  "version": 1,
  "description": "Schema contract: every field the dashboard renders. If you add a field to either side (pipeline output or dashboard JS), add it here. tests/test_feed_contract.py enforces the contract.",
  "last_updated": "2026-04-09",
  "fields": {
    "issue_id":              { "type": "string",  "required": true },
    "title":                 { "type": "string",  "required": true },
    "priority":              { "type": "string",  "required": true, "enum": ["P0","P1","P2","P3"] },
    "score":                 { "type": "integer", "required": true },
    "summary":               { "type": "string",  "required": false },
    "cves":                  { "type": "array",   "required": false },
    "cvss_score":            { "type": "number",  "required": false },
    "cvss_severity":         { "type": "string",  "required": false },
    "cwe_ids":               { "type": "array",   "required": false },
    "fda_risk_class":        { "type": ["string","null"], "required": false },
    "kev_required_action":   { "type": "string",  "required": false },
    "kev_due_date":          { "type": "string",  "required": false },
    "kev_vendor":            { "type": "string",  "required": false },
    "kev_product":           { "type": "string",  "required": false },
    "kev_vulnerability_name": { "type": "string", "required": false },
    "is_kev_medical_device": { "type": "boolean", "required": false },
    "vendor":                { "type": "string",  "required": false },
    "affected_products":     { "type": "array",   "required": false },
    "affected_versions":     { "type": "array",   "required": false },
    "handling_warnings":     { "type": "array",   "required": false },
    "remediation_steps":     { "type": "array",   "required": false },
    "actions":               { "type": "array",   "required": false },
    "sources":               { "type": "array",   "required": false },
    "canonical_link":        { "type": "string",  "required": false },
    "published_dates":       { "type": "array",   "required": false },
    "first_seen_at":         { "type": "string",  "required": false },
    "last_seen_at":          { "type": "string",  "required": false },
    "healthcare_relevant":   { "type": "boolean", "required": false },
    "healthcare_category":   { "type": "string",  "required": false },
    "nvd_description":       { "type": "string",  "required": false },
    "recommended_patterns":  { "type": "array",   "required": false, "added_by": "Problem 1 fix (commit 3)" },
    "tasks_by_role":         { "type": "object",  "required": false, "added_by": "Problem 1 fix (commit 3)" },
    "reasoning":             { "type": "string",  "required": false, "added_by": "Problem 1 fix (commit 3)" },
    "epss_score":            { "type": ["number","null"], "required": false, "added_by": "EPSS enrichment" },
    "epss_percentile":       { "type": ["number","null"], "required": false, "added_by": "EPSS enrichment" }
  }
}
